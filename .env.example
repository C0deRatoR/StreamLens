# Environment variables for StreamLens
# Copy this file to .env and fill in your values

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/streamlens
DB_HOST=localhost
DB_PORT=5432
DB_NAME=streamlens
DB_USER=your_username
DB_PASSWORD=your_password

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True
SECRET_KEY=your-secret-key-here-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# TMDB API (Get from https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3

# Spark Configuration
SPARK_MASTER=local[*]
SPARK_DRIVER_MEMORY=4g
SPARK_EXECUTOR_MEMORY=4g

# Data Paths
DATA_RAW_PATH=./data/raw
DATA_PROCESSED_PATH=./data/processed
DATA_EXTERNAL_PATH=./data/external

# Model Paths
MODEL_SAVE_PATH=./models/saved

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/streamlens.log

# CORS (for frontend)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Recommendation Settings
TOP_N_RECOMMENDATIONS=10
MIN_RATING_THRESHOLD=3.0
